package project;

import java.sql.*;

class bk{
	public void addrec(int cid,String cname,String cadd,String city,int pin,long phone,int indep) {
		Connection con=null;
		Statement smt=null;
		try{
			Class.forName("org.sqlite.JDBC");
			con=DriverManager.getConnection("jdbc:sqlite:C:\\sql\\bank.db");
			con.setAutoCommit(true);
			System.out.println("database opened succusfully");
			smt=con.createStatement();
			String query="insert into banking values(?,?,?,?,?,?,?)";
			PreparedStatement presmt=con.prepareStatement(query);
			presmt.setInt(1,cid);
			presmt.setString(2,cname);
			presmt.setString(3,cadd);
			presmt.setString(4,city);
			presmt.setInt(5,pin);
			presmt.setLong(6,phone);
			presmt.setInt(7,indep);
			
			presmt.executeUpdate();
			//con.commit();
			presmt.close();
			}
		catch(Exception e){
			System.out.println(e.getMessage());
			}
			System.out.println("data base connected successfull");
	}
			
}
